model EmployeeAbsence {
  id              String       @id @default(uuid())
  collaboratorId  String       @map("collaborator_id")
  collaborator    Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  dataFalta       DateTime     @map("data_falta")
  tipo            String       // JUSTIFICADA, NAO_JUSTIFICADA
  diasFalta       Int          @default(1) @map("dias_falta")
  motivo          String?      @map("motivo")
  observacao      String?
  fileName        String?      @map("file_name")
  fileType        String?      @map("file_type")
  fileUrl         String?      @map("file_url") @db.Text
  responsavelId   String?      @map("responsavel_id")
  responsavelNome String       @map("responsavel_nome")
  
  companyId       String?      @map("company_id")
  company         Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  oficinaId       String?      @map("oficina_id")
  oficina         Oficina?     @relation(fields: [oficinaId], references: [id], onDelete: SetNull)

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([collaboratorId])
  @@index([companyId])
  @@index([oficinaId])
  @@map("employee_absences")
}

model Product {
  id                    String              @id @default(uuid())
  codigo                String?
  codigoBarras          String?
  descricao             String
  unidade               String?
  valorCusto            Float               @default(0.0)
  custoMedio            Float               @default(0.0)
  quantidadeEstoque     Float               @default(0.0)
  ncm                   String?
  cest                  String?
  cfopEntrada           String?
  
  tributacaoMunicipalId String?
  tributacaoMunicipal   TributacaoMunicipal? @relation(fields: [tributacaoMunicipalId], references: [id], onDelete: SetNull)
  
  tributacaoEstadualId  String?
  tributacaoEstadual    TributacaoEstadual?  @relation(fields: [tributacaoEstadualId], references: [id], onDelete: SetNull)
  
  tributacaoFederalId   String?
  tributacaoFederal     TributacaoFederal?   @relation(fields: [tributacaoFederalId], references: [id], onDelete: SetNull)
  
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  movements             StockMovement[]
  nfeItems              NfeItem[]
  
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([companyId])
  @@index([tributacaoMunicipalId])
  @@index([tributacaoEstadualId])
  @@index([tributacaoFederalId])
}

model TributacaoMunicipal {
  id                 String    @id @default(uuid())
  codigo             String
  descricao          String
  municipio          String?
  codigoServico      String?
  aliquotaIss        Float?
  retencaoIss        Boolean   @default(false)
  situacaoTributaria String?
  status             String    @default("ATIVO")
  
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  products           Product[]
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([companyId, codigo])
  @@index([companyId])
}

model TributacaoEstadual {
  id                 String    @id @default(uuid())
  codigo             String
  descricao          String
  uf                 String?
  cfop               String?
  cstIcms            String?
  csosn              String?
  aliquotaIcms       Float?
  fcp                Float?
  difal              Float?
  observacao         String?
  status             String    @default("ATIVO")
  
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  products           Product[]
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([companyId, codigo])
  @@index([companyId])
}

model TributacaoFederal {
  id                 String    @id @default(uuid())
  codigo             String
  descricao          String
  cstPis             String?
  cstCofins          String?
  cstIpi             String?
  aliquotaPis        Float?
  aliquotaCofins     Float?
  aliquotaIpi        Float?
  naturezaReceita    String?
  status             String    @default("ATIVO")
  
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  products           Product[]
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([companyId, codigo])
  @@index([companyId])
}

model StockMovement {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tipo            String   // ENTRADA, SAIDA
  quantidade      Float
  valorUnitario   Float
  valorTotal      Float
  origem          String   // IMPORTACAO_NFE, AJUSTE_MANUAL, VENDA, etc.
  documentoOrigem String?  // ID ou número da NF-e
  userId          String?
  createdAt       DateTime @default(now())

  @@index([productId])
}

model NfeImport {
  id               String    @id @default(uuid())
  chaveAcesso      String    @unique
  numeroNf         String
  serie            String?
  dataEmissao      DateTime
  dataEntrada      DateTime  @default(now())
  naturezaOperacao String?
  valorProdutos    Float
  valorFrete       Float     @default(0.0)
  valorSeguro      Float     @default(0.0)
  valorDesconto    Float     @default(0.0)
  valorTotal       Float
  xmlOriginal      String    @db.Text
  status           String    @default("IMPORTADO") // IMPORTADO, CANCELADO
  
  supplierId       String
  supplier         Supplier  @relation(fields: [supplierId], references: [id])
  
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  items            NfeItem[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@index([supplierId])
}

model NfeItem {
  id                  String     @id @default(uuid())
  nfeImportId         String
  nfeImport           NfeImport  @relation(fields: [nfeImportId], references: [id], onDelete: Cascade)
  
  productId           String?
  product             Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  
  codigoProduto       String
  codigoBarras        String?
  descricao           String
  ncm                 String?
  cest                String?
  cfop                String?
  unidade             String?
  quantidade          Float
  valorUnitario       Float
  valorTotal          Float
  
  // Impostos
  icmsCst             String?
  icmsCsosn           String?
  icmsBaseCalculo     Float?
  icmsAliquota        Float?
  icmsValor           Float?
  
  ipiCst              String?
  ipiBaseCalculo      Float?
  ipiAliquota         Float?
  ipiValor            Float?
  
  pisCst              String?
  pisBaseCalculo      Float?
  pisAliquota         Float?
  pisValor            Float?
  
  cofinsCst           String?
  cofinsBaseCalculo   Float?
  cofinsAliquota      Float?
  cofinsValor         Float?
  
  issCodigoServico    String?
  issAliquota         Float?
  issValor            Float?

  @@index([nfeImportId])
  @@index([productId])
}



