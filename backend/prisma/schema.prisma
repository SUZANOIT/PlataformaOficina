  plan            SaaSPlan  @relation(fields: [planoId], references: [id], onDelete: Cascade)
  valor           Float
  formaPagamento  String    @map("forma_pagamento") // Mercado Pago, Asaas, PagSeguro, Stripe
  status          String    @default("Ativa") // Ativa, Pendente, Atrasada, Cancelada, Expirada
  dataInicio      DateTime  @default(now()) @map("data_inicio")
  dataRenovacao   DateTime  @map("data_renovacao")
  ultimoPagamento DateTime? @map("ultimo_pagamento")
  proximoPagamento DateTime? @map("proximo_pagamento")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("saas_subscriptions")
}

model SaaSModule {
