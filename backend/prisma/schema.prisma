// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // ADMINISTRADOR, FINANCEIRO, ATENDIMENTO, MECANICO, GESTOR
  status    String   @default("ATIVO") // ATIVO, INATIVO
  
  // Níveis de acesso / Permissões (Granular)
  roleAdmin        Boolean @default(false)
  roleOrcamentista Boolean @default(false)
  roleContasPagar   Boolean @default(false)
  roleContasReceber Boolean @default(false)
  roleContabilidade Boolean @default(false)
  
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([companyId])
}

model Company {
  id               String   @id @default(uuid())
  razaoSocial      String
  nomeFantasia     String?
  cnpj             String   @unique
  cnpjSemMascara   String   @unique
  inscricaoEstadual String?
  
  // Cadastro da Oficina
  endereco          String?
  telefone          String?
  whatsapp          String?
  email             String?
  logo              String?  // Base64 ou URL da logo personalizada
  regimeTributario  String?  // Regime tributário da oficina
  
  parentCompanyId  String?
  parentCompany    Company?  @relation("SubCompanies", fields: [parentCompanyId], references: [id])
  subCompanies     Company[] @relation("SubCompanies")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  users            User[]
  clients          Client[]
  suppliers        Supplier[]
  collaborators    Collaborator[]
  vehicles         Vehicle[]
  taxSettings      TaxSetting[]
  emailConfigs     EmailConfig[]
  quotes           Quote[]
  financialPayables    FinancialPayable[]
  financialReceivables FinancialReceivable[]
  plataformasGestao    PlataformaGestao[]
  financialCategories  FinancialCategory[]

  @@index([cnpj])
  @@index([parentCompanyId])
}

model Client {
  id        String   @id @default(uuid())
  nome      String
  empresa   String?
  cnpj      String?
  telefone  String?
  email     String?
  cidade    String?
  estado    String?
  
  // Novos campos (ReceitaWS)
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cep                String?
  dataSituacao       String?
  atividadePrincipal String?

  // Frotas
  whatsapp           String?
  status             String   @default("ATIVO") // ATIVO, INATIVO
  veiculos           Vehicle[]

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]

  @@index([email])
  @@index([cnpj])
  @@index([companyId])
}

model Quote {
  id                  String      @id @default(uuid())
  numeroOrcamento     Int         @unique @default(autoincrement())
  
  companyId           String
  company             Company     @relation(fields: [companyId], references: [id])
  
  clientId            String
  client              Client      @relation(fields: [clientId], references: [id])
  
  condicaoPagamento   String
  parcelas            Int?        // Se for parcelado
  valorParcela        Float?      // Se for parcelado
  
  validade            String      // Ex: "Proposta válida por 7 dias"
  garantia            String?     // Ex: "Garantia de 90 dias"
  prazoExecucao       String?     // Ex: "5 dias úteis"
  observacao          String?     // Campo de observações gerais
  
  // Dados do Veículo (Opcional)
  veiculoMarca        String?
  veiculoModelo       String?
  veiculoAno          String?
  veiculoPlaca        String?
  veiculoPrefixo      String?
  veiculoAnoFabricacao String?
  veiculoAnoModelo     String?
  veiculoChassi        String?
  veiculoRenavam       String?
  veiculoFrota         String?
  veiculoSubfrota      String?
  veiculoHodometro     String?
  veiculoTipo          String?
  
  subtotal            Float
  total               Float
  status              String      @default("Orçamento")
  
  items               QuoteItem[]
  financialReceivables FinancialReceivable[]
  linkedPayables      PayableQuoteLink[]
  linkedReceivables   ReceivableQuoteLink[]
  
  plataformaGestaoId  String?
  plataformaGestao    PlataformaGestao? @relation(fields: [plataformaGestaoId], references: [id], onDelete: SetNull)
  osExterna           String?
  
  oficinaId           String?
  oficina             Oficina? @relation(fields: [oficinaId], references: [id], onDelete: SetNull)
  notaFiscalDescricao String?
  
  veiculoId           String?
  veiculo             Vehicle?    @relation(fields: [veiculoId], references: [id], onDelete: SetNull)
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([plataformaGestaoId])
  @@index([oficinaId])
  @@index([veiculoId])
}

model QuoteItem {
  id            String   @id @default(uuid())
  quoteId       String
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  descricao     String
  quantidade    Int
  valorUnitario Float
  valorTotal    Float
  tipo          String   @default("Peça")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([quoteId])
}

model EmailConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int
  user      String
  password  String
  fromName  String?
  fromEmail String?
  
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model FinancialPayable {
  id                    String                 @id @default(uuid())
  numeroLancamento      Int                    @unique @default(autoincrement())
  companyId             String
  company               Company                @relation(fields: [companyId], references: [id])
  fornecedor            String
  categoria             String
  centroCusto           String
  descricao             String
  valor                 Float
  dataEmissao           DateTime
  vencimento            DateTime
  dataPagamento         DateTime?
  formaPagamento        String
  responsavel           String
  observacoes           String?
  status                String                 @default("PENDENTE") // PENDENTE, EM ANÁLISE, APROVADA, REPROVADA, PAGA, CANCELADA, VENCIDA
  
  recorrente            Boolean                @default(false)
  tipoRecorrencia       String?                // DIARIA, SEMANAL, QUINZENAL, MENSAL, BIMESTRAL, TRIMESTRAL, SEMESTRAL, ANUAL
  quantidadeParcelas    Int?
  parcelaAtual          Int?                   @default(1)
  dataFinalRecorrencia  DateTime?
  pagamentoAutomatico   Boolean                @default(false)
  parentRecurrenceId    String?                // Identificador para agrupar parcelas da mesma recorrência
  
  attachments           FinancialAttachment[]
  audits                FinancialAudit[]
  linkedQuotes          PayableQuoteLink[]
  salaryAdvance         SalaryAdvance?
  
  responsavel_lancamento_id   String?
  responsavel_lancamento_nome String?
  data_criacao               DateTime               @default(now())

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([companyId])
}

model FinancialReceivable {
  id                    String                 @id @default(uuid())
  numeroRecebimento     Int                    @unique @default(autoincrement())
  companyId             String
  company               Company                @relation(fields: [companyId], references: [id])
  cliente               String
  categoria             String
  descricao             String
  valor                 Float
  dataEmissao           DateTime
  vencimento            DateTime
  dataRecebimento       DateTime?
  formaRecebimento      String
  responsavel           String
  observacoes           String?
  status                String                 @default("PENDENTE") // PENDENTE, EM ANÁLISE, APROVADA, REPROVADA, RECEBIDA, CANCELADA, VENCIDA

  quoteId               String?
  quote                 Quote?                 @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  attachments           FinancialAttachment[]
  audits                FinancialAudit[]
  linkedQuotes          ReceivableQuoteLink[]
  
  responsavel_lancamento_id   String?
  responsavel_lancamento_nome String?
  data_criacao               DateTime               @default(now())

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([companyId])
  @@index([quoteId])
}

model FinancialAttachment {
  id                    String                 @id @default(uuid())
  payableId             String?
  payable               FinancialPayable?      @relation(fields: [payableId], references: [id], onDelete: Cascade)
  receivableId          String?
  receivable            FinancialReceivable?   @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  
  fileName              String
  fileType              String                 // PDF, JPG, JPEG, PNG
  fileUrl               String                 // Base64 ou URL de visualização
  createdAt             DateTime               @default(now())

  @@index([payableId])
  @@index([receivableId])
}

model FinancialAudit {
  id                    String                 @id @default(uuid())
  payableId             String?
  payable               FinancialPayable?      @relation(fields: [payableId], references: [id], onDelete: Cascade)
  receivableId          String?
  receivable            FinancialReceivable?   @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  
  action                String                 // CREATE, UPDATE, DELETE, STATUS_CHANGE, APPROVAL, REJECTION
  previousStatus        String?
  newStatus             String?
  user                  String                 // E-mail/Nome do executor
  changes               String?                // Descrição detalhada das mudanças
  comments              String?                // Comentários de aprovação/reprovação
  createdAt             DateTime               @default(now())

  @@index([payableId])
  @@index([receivableId])
}

model Supplier {
  id                 String   @id @default(uuid())
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String?  @unique
  cnpjSemMascara     String?  @unique
  telefone           String?
  email              String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cep                String?
  cidade             String?
  estado             String?
  dataSituacao       String?
  atividadePrincipal String?
  
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([cnpj])
  @@index([companyId])
}

model Vehicle {
  id                 String   @id @default(uuid())
  clienteId          String
  client             Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  placa              String   @unique
  renavam            String?
  chassi             String?
  vin                String?
  frota              String?
  subfrota           String?
  prefixo            String?
  
  marca              String
  modelo             String
  versao             String?
  anoFabricacao      Int
  anoModelo          Int
  cor                String?
  combustivel        String?
  tipoVeiculo        String?
  kmAtual            Int      @default(0)
  status             String   @default("ATIVO") // ATIVO, EM_MANUTENCAO, INATIVO, VENDIDO
  observacoes        String?
  
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  trocasOleoMotor    TrocaOleoMotor[]
  trocasOleoCambio   TrocaOleoCambio[]
  events             VehicleEvent[]
  quotes             Quote[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clienteId])
  @@index([placa])
  @@index([companyId])
}

model ConsultaPlaca {
  id           String   @id @default(uuid())
  placa        String   @unique
  retornoApi   String   // JSON stringified
  dataConsulta DateTime @default(now())
  status       String   @default("SUCESSO")
}

model Oficina {
  id                 String   @id @default(uuid())
  nome               String
  cnpj               String   @unique
  responsavel        String?
  telefone           String?
  whatsapp           String?
  email              String?
  endereco           String?
  servicosRealizados String?
  observacoes        String?
  
  // Dados Bancários
  banco              String?
  agencia            String?
  contaCorrente      String?
  tipoConta          String?
  chavePix           String?
  favorecido         String?
  cpfCnpjFavorecido  String?
  
  trocasOleoMotor    TrocaOleoMotor[]
  trocasOleoCambio   TrocaOleoCambio[]
  salaryAdvances     SalaryAdvance[]
  collaborators      Collaborator[]
  quotes             Quote[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TrocaOleoMotor {
  id               String   @id @default(uuid())
  veiculoId        String
  veiculo          Vehicle  @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  dataTroca        DateTime
  kmTroca          Int
  tipoOleo         String?
  quantidade       Float?
  proximaTrocaKm   Int
  proximaTrocaData DateTime
  oficinaId        String
  oficina          Oficina  @relation(fields: [oficinaId], references: [id])
  valor            Float
  observacoes      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([veiculoId])
  @@index([oficinaId])
}

model TrocaOleoCambio {
  id               String   @id @default(uuid())
  veiculoId        String
  veiculo          Vehicle  @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  tipoCambio       String   // MANUAL, AUTOMATICO, CVT
  dataTroca        DateTime
  kmTroca          Int
  oleoUtilizado    String?
  quantidade       Float?
  proximaTrocaKm   Int
  proximaTrocaData DateTime
  oficinaId        String
  oficina          Oficina  @relation(fields: [oficinaId], references: [id])
  valor            Float
  observacoes      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([veiculoId])
  @@index([oficinaId])
}

model VehicleEvent {
  id          String   @id @default(uuid())
  veiculoId   String
  veiculo     Vehicle  @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  tipo        String   // TROCA_OLEO_MOTOR, TROCA_OLEO_CAMBIO, REVISAO, MANUTENCAO, KM, ABASTECIMENTO, MULTA, SINISTRO, ALTERACAO
  data        DateTime
  km          Int?
  descricao   String
  valor       Float?
  oficinaId   String?
  createdAt   DateTime @default(now())

  @@index([veiculoId])
}

model Collaborator {
  id                 String   @id @default(uuid())
  nome               String
  cpf                String?  @unique
  cpfSemMascara      String?  @unique
  telefone           String?
  whatsapp           String?
  email              String?  @unique
  cargo              String?
  departamento       String?
  dataAdmissao       DateTime?
  salario            Float?
  status             String   @default("ATIVO") // ATIVO, INATIVO
  observacoes        String?
  
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  advances  SalaryAdvance[]
  oficinaId String?
  oficina   Oficina? @relation(fields: [oficinaId], references: [id], onDelete: SetNull)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([cpf])
  @@index([email])
  @@index([companyId])
  @@index([oficinaId])
}

model PayableQuoteLink {
  id             String           @id @default(uuid())
  payableId      String
  payable        FinancialPayable @relation(fields: [payableId], references: [id], onDelete: Cascade)
  quoteId        String
  quote          Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  valorVinculado Float            // O valor alocado deste lançamento para este orçamento

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([payableId])
  @@index([quoteId])
  @@unique([payableId, quoteId])
}

model ReceivableQuoteLink {
  id             String              @id @default(uuid())
  receivableId   String
  receivable     FinancialReceivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  quoteId        String
  quote          Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  valorVinculado Float               // O valor alocado deste lançamento para este orçamento

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([receivableId])
  @@index([quoteId])
  @@unique([receivableId, quoteId])
}

model TaxSetting {
  id        String   @id @default(uuid())
  nome      String
  aliquota  Float
  tipo      String   @default("FATURAMENTO") // FATURAMENTO, RETENCAO, OUTRO
  status    String   @default("ATIVO") // ATIVO, INATIVO
  
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model PlataformaGestao {
  id             String   @id @default(uuid())
  razaoSocial    String
  nomeFantasia   String
  cnpj           String
  cnpjSemMascara String
  telefone       String
  email          String
  responsavel    String?
  status         String   @default("ATIVO") // ATIVO, INATIVO
  observacoes    String?
  
  // Endereço
  endereco       String?
  cidade         String?
  estado         String?
  cep            String?

  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])

  quotes         Quote[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, cnpj])
  @@unique([companyId, cnpjSemMascara])
  @@index([cnpj])
  @@index([companyId])
}

model SalaryAdvance {
  id                String             @id @default(uuid())
  collaboratorId    String
  collaborator      Collaborator       @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  valor             Float
  formaPagamento    String
  status            String             @default("PENDENTE") // PENDENTE, DESCONTADO_EM_FOLHA
  data              DateTime           @default(now())
  responsavel       String
  observacoes       String?
  numeroComprovante String             @unique
  payableId         String?            @unique
  payable           FinancialPayable?  @relation(fields: [payableId], references: [id], onDelete: SetNull)
  pdfs              SalaryAdvancePdf[]
  
  oficinaId         String?
  oficina           Oficina?           @relation(fields: [oficinaId], references: [id], onDelete: SetNull)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([collaboratorId])
  @@index([payableId])
  @@index([oficinaId])
}

model SalaryAdvancePdf {
  id              String        @id @default(uuid())
  salaryAdvanceId String
  salaryAdvance   SalaryAdvance @relation(fields: [salaryAdvanceId], references: [id], onDelete: Cascade)
  fileName        String
  generatedAt     DateTime      @default(now())

  @@index([salaryAdvanceId])
}

model FinancialCategory {
  id         String   @id @default(uuid())
  name       String
  type       String   // 'PAYABLE' | 'RECEIVABLE' | 'BOTH'
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, name, type])
  @@index([companyId])
}
