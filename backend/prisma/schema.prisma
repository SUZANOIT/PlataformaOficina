// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN, MANAGER, WORKSHOP, CLIENT
  status    String   @default("ATIVO") // ATIVO, INATIVO
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Company {
  id               String   @id @default(uuid())
  razaoSocial      String
  nomeFantasia     String?
  cnpj             String   @unique
  cnpjSemMascara   String   @unique
  inscricaoEstadual String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  quotes           Quote[]
  financialPayables    FinancialPayable[]
  financialReceivables FinancialReceivable[]

  @@index([cnpj])
}

model Client {
  id        String   @id @default(uuid())
  nome      String
  empresa   String?
  cnpj      String?
  telefone  String?
  email     String?
  cidade    String?
  estado    String?
  
  // Novos campos (ReceitaWS)
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cep                String?
  dataSituacao       String?
  atividadePrincipal String?

  // Frotas
  whatsapp           String?
  status             String   @default("ATIVO") // ATIVO, INATIVO
  veiculos           Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]

  @@index([email])
  @@index([cnpj])
}

model Quote {
  id                  String      @id @default(uuid())
  numeroOrcamento     Int         @unique @default(autoincrement())
  
  companyId           String
  company             Company     @relation(fields: [companyId], references: [id])
  
  clientId            String
  client              Client      @relation(fields: [clientId], references: [id])
  
  condicaoPagamento   String
  parcelas            Int?        // Se for parcelado
  valorParcela        Float?      // Se for parcelado
  
  validade            String      // Ex: "Proposta válida por 7 dias"
  garantia            String?     // Ex: "Garantia de 90 dias"
  prazoExecucao       String?     // Ex: "5 dias úteis"
  observacao          String?     // Campo de observações gerais
  
  // Dados do Veículo (Opcional)
  veiculoMarca        String?
  veiculoModelo       String?
  veiculoAno          String?
  veiculoPlaca        String?
  
  subtotal            Float
  total               Float
  status              String      @default("Orçamento")
  
  items               QuoteItem[]
  financialReceivables FinancialReceivable[]
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([companyId])
  @@index([clientId])
}

model QuoteItem {
  id            String   @id @default(uuid())
  quoteId       String
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  descricao     String
  quantidade    Int
  valorUnitario Float
  valorTotal    Float
  tipo          String   @default("Peça")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([quoteId])
}

model EmailConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int
  user      String
  password  String
  fromName  String?
  fromEmail String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinancialPayable {
  id                    String                 @id @default(uuid())
  numeroLancamento      Int                    @unique @default(autoincrement())
  companyId             String
  company               Company                @relation(fields: [companyId], references: [id])
  fornecedor            String
  categoria             String
  centroCusto           String
  descricao             String
  valor                 Float
  dataEmissao           DateTime
  vencimento            DateTime
  dataPagamento         DateTime?
  formaPagamento        String
  responsavel           String
  observacoes           String?
  status                String                 @default("PENDENTE") // PENDENTE, EM ANÁLISE, APROVADA, REPROVADA, PAGA, CANCELADA, VENCIDA
  
  recorrente            Boolean                @default(false)
  tipoRecorrencia       String?                // DIARIA, SEMANAL, QUINZENAL, MENSAL, BIMESTRAL, TRIMESTRAL, SEMESTRAL, ANUAL
  quantidadeParcelas    Int?
  parcelaAtual          Int?                   @default(1)
  dataFinalRecorrencia  DateTime?
  pagamentoAutomatico   Boolean                @default(false)
  parentRecurrenceId    String?                // Identificador para agrupar parcelas da mesma recorrência
  
  attachments           FinancialAttachment[]
  audits                FinancialAudit[]
  
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([companyId])
}

model FinancialReceivable {
  id                    String                 @id @default(uuid())
  numeroRecebimento     Int                    @unique @default(autoincrement())
  companyId             String
  company               Company                @relation(fields: [companyId], references: [id])
  cliente               String
  categoria             String
  descricao             String
  valor                 Float
  dataEmissao           DateTime
  vencimento            DateTime
  dataRecebimento       DateTime?
  formaRecebimento      String
  responsavel           String
  observacoes           String?
  status                String                 @default("PENDENTE") // PENDENTE, EM ANÁLISE, APROVADA, REPROVADA, RECEBIDA, CANCELADA, VENCIDA

  quoteId               String?
  quote                 Quote?                 @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  attachments           FinancialAttachment[]
  audits                FinancialAudit[]
  
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([companyId])
  @@index([quoteId])
}

model FinancialAttachment {
  id                    String                 @id @default(uuid())
  payableId             String?
  payable               FinancialPayable?      @relation(fields: [payableId], references: [id], onDelete: Cascade)
  receivableId          String?
  receivable            FinancialReceivable?   @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  
  fileName              String
  fileType              String                 // PDF, JPG, JPEG, PNG
  fileUrl               String                 // Base64 ou URL de visualização
  createdAt             DateTime               @default(now())

  @@index([payableId])
  @@index([receivableId])
}

model FinancialAudit {
  id                    String                 @id @default(uuid())
  payableId             String?
  payable               FinancialPayable?      @relation(fields: [payableId], references: [id], onDelete: Cascade)
  receivableId          String?
  receivable            FinancialReceivable?   @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  
  action                String                 // CREATE, UPDATE, DELETE, STATUS_CHANGE, APPROVAL, REJECTION
  previousStatus        String?
  newStatus             String?
  user                  String                 // E-mail/Nome do executor
  changes               String?                // Descrição detalhada das mudanças
  comments              String?                // Comentários de aprovação/reprovação
  createdAt             DateTime               @default(now())

  @@index([payableId])
  @@index([receivableId])
}

model Supplier {
  id                 String   @id @default(uuid())
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String?  @unique
  cnpjSemMascara     String?  @unique
  telefone           String?
  email              String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cep                String?
  cidade             String?
  estado             String?
  dataSituacao       String?
  atividadePrincipal String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([cnpj])
}

model Vehicle {
  id                 String   @id @default(uuid())
  clienteId          String
  client             Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  placa              String   @unique
  renavam            String?
  chassi             String?
  vin                String?
  codigoFipe         String?
  codigoInterno      String?
  frota              String?
  subfrota           String?
  
  marca              String
  modelo             String
  versao             String?
  anoFabricacao      Int
  anoModelo          Int
  cor                String?
  combustivel        String?
  categoria          String?
  tipoVeiculo        String?
  municipio          String?
  uf                 String?
  kmAtual            Int      @default(0)
  mediaConsumo       Float?
  status             String   @default("ATIVO") // ATIVO, EM_MANUTENCAO, INATIVO, VENDIDO
  observacoes        String?
  
  trocasOleoMotor    TrocaOleoMotor[]
  trocasOleoCambio   TrocaOleoCambio[]
  events             VehicleEvent[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clienteId])
  @@index([placa])
}

model ConsultaPlaca {
  id           String   @id @default(uuid())
  placa        String   @unique
  retornoApi   String   // JSON stringified
  dataConsulta DateTime @default(now())
  status       String   @default("SUCESSO")
}

model Oficina {
  id                 String   @id @default(uuid())
  nome               String
  cnpj               String   @unique
  responsavel        String?
  telefone           String?
  whatsapp           String?
  email              String?
  endereco           String?
  servicosRealizados String?
  observacoes        String?
  
  trocasOleoMotor    TrocaOleoMotor[]
  trocasOleoCambio   TrocaOleoCambio[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TrocaOleoMotor {
  id               String   @id @default(uuid())
  veiculoId        String
  veiculo          Vehicle  @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  dataTroca        DateTime
  kmTroca          Int
  tipoOleo         String?
  quantidade       Float?
  proximaTrocaKm   Int
  proximaTrocaData DateTime
  oficinaId        String
  oficina          Oficina  @relation(fields: [oficinaId], references: [id])
  valor            Float
  observacoes      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([veiculoId])
  @@index([oficinaId])
}

model TrocaOleoCambio {
  id               String   @id @default(uuid())
  veiculoId        String
  veiculo          Vehicle  @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  tipoCambio       String   // MANUAL, AUTOMATICO, CVT
  dataTroca        DateTime
  kmTroca          Int
  oleoUtilizado    String?
  quantidade       Float?
  proximaTrocaKm   Int
  proximaTrocaData DateTime
  oficinaId        String
  oficina          Oficina  @relation(fields: [oficinaId], references: [id])
  valor            Float
  observacoes      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([veiculoId])
  @@index([oficinaId])
}

model VehicleEvent {
  id          String   @id @default(uuid())
  veiculoId   String
  veiculo     Vehicle  @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  tipo        String   // TROCA_OLEO_MOTOR, TROCA_OLEO_CAMBIO, REVISAO, MANUTENCAO, KM, ABASTECIMENTO, MULTA, SINISTRO, ALTERACAO
  data        DateTime
  km          Int?
  descricao   String
  valor       Float?
  oficinaId   String?
  createdAt   DateTime @default(now())

  @@index([veiculoId])
}
